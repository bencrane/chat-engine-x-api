{
    "document": {
      "title": "MCMIS Vehicle Inspection Data Set Dictionary",
      "revision": 5,
      "date": "2025-10-15",
      "total_pages": 84
    },
    "tables": {
      "vehicle_inspection_file": {
        "description": "Main inspection record table containing all core inspection data fields.",
        "fields": [
          {"order": 1, "field_name": "CHANGE_DATE", "description": "Date and time record was last updated", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 2, "field_name": "INSPECTION_ID", "description": "Unique identifying number assigned to an inspection record", "length": 8, "type": "N", "format": null},
          {"order": 3, "field_name": "DOT_NUMBER", "description": "USDOT number assigned by MCMIS to a census record. Each motor carrier should have only one active census number.", "length": 8, "type": "N", "format": null},
          {"order": 4, "field_name": "REPORT_STATE", "description": "State/District/Province which uploads the inspection, usually where inspection was conducted.", "length": 2, "type": "A/N", "format": "See State Abbreviations"},
          {"order": 5, "field_name": "REPORT_NUMBER", "description": "A number identifying the inspection report.", "length": 10, "type": "A/N", "format": "SS######## where SS is State code or US for Federal Inspections"},
          {"order": 6, "field_name": "INSP_DATE", "description": "Date the inspection was conducted.", "length": 8, "type": "A/N", "format": "YYYYMMDD"},
          {"order": 7, "field_name": "INSP_START_TIME", "description": "Time the inspection started. Midnight is recorded as 2400. 9999 = Time unknown.", "length": 4, "type": "A/N", "format": "HHMM (Military Time)"},
          {"order": 8, "field_name": "INSP_END_TIME", "description": "Time the inspection ended. Midnight is recorded as 2400. 9999 = Time unknown.", "length": 4, "type": "A/N", "format": "HHMM (Military Time)"},
          {"order": 9, "field_name": "REGISTRATION_DATE", "description": "Date the certification of correction of defects was registered.", "length": 8, "type": "A/N", "format": "YYYYMMDD"},
          {"order": 10, "field_name": "REGION", "description": "FHWA/FMCSA region in which the inspection took place.", "length": 2, "type": "A/N", "format": "1, 3-10", "values": {
            "1": "CT, ME, MA, NH, NY, NJ, RI, VT, PR, VI",
            "3": "DE, DC, MD, PA, VA, WV",
            "4": "AL, GA, FL, MS, NC, SC, TN, KY",
            "5": "IL, IN, MI, OH, MN, WI",
            "6": "AR, LA, NM, OK, TX",
            "7": "IA, KS, MO, NE",
            "8": "CO, MT, ND, SD, UT, WY",
            "9": "AZ, CA, NV, HI, GU, AS",
            "10": "AK, ID, OR, WA"
          }},
          {"order": 11, "field_name": "CI_STATUS_CODE", "description": "Indicates the status of the inspection.", "length": 1, "type": "A/N", "values": {
            "U": "Unprocessed",
            "T": "To Census Search",
            "C": "Complete",
            "D": "Duplicate",
            "N": "Nonmatch",
            "H": "FMCSA hold",
            "I": "Intrastate",
            "P": "Potential Resolution",
            "X": "Non-motor carrier"
          }},
          {"order": 12, "field_name": "LOCATION", "description": "State assigned code representing the physical location of the inspection.", "length": 6, "type": "A/N", "format": "1-5, 9"},
          {"order": 13, "field_name": "LOCATION_DESC", "description": "Physical location where the inspection took place.", "length": 30, "type": "A/N", "format": null},
          {"order": 14, "field_name": "COUNTY_CODE_STATE", "description": "State/District/Province of the county where the inspection took place.", "length": 2, "type": "A/N", "format": "See State Abbreviations"},
          {"order": 15, "field_name": "COUNTY_CODE", "description": "FIPS code identifying the county in which the inspection occurred.", "length": 3, "type": "A/N", "format": "See County Codes"},
          {"order": 16, "field_name": "INSP_LEVEL_ID", "description": "Identifies the level of the inspection.", "length": 8, "type": "N", "values": {
            "1": "Full",
            "2": "Walk-Around",
            "3": "Driver-Only",
            "4": "Special Study",
            "5": "Terminal",
            "99": "Invalid"
          }},
          {"order": 17, "field_name": "SERVICE_CENTER", "description": "Service Center Region the inspection occurred in.", "length": 2, "type": "A/N", "values": {
            "MW": "Midwest",
            "EA": "East",
            "SH": "South",
            "WE": "West"
          }},
          {"order": 18, "field_name": "CENSUS_SOURCE_ID", "description": "USDOT NUMBER verification method.", "length": 8, "type": "N", "values": {
            "1": "Matchware",
            "2": "Manual Census Search",
            "3": "Matching Algorithm",
            "4": "Pen-Based (not used on Crashes)",
            "5": "SafetyNet Uploaded and not changed",
            "null": "Unknown"
          }},
          {"order": 19, "field_name": "INSP_FACILITY", "description": "Type of facility where the inspection was conducted.", "length": 1, "type": "A/N", "values": {
            "F": "Fixed",
            "R": "Roadside",
            "null": "N/A"
          }},
          {"order": 20, "field_name": "SHIPPER_NAME", "description": "Name of the shipping company.", "length": 120, "type": "A/N", "format": null},
          {"order": 21, "field_name": "SHIPPING_PAPER_NUMBER", "description": "Unique number on the shipping papers or 'NONE' if no shipping papers are present.", "length": 15, "type": "A/N", "format": null},
          {"order": 22, "field_name": "CARGO_TANK", "description": "Three-character indicator of the cargo tank type. Comes from ASPEN.", "length": 3, "type": "A/N", "format": null},
          {"order": 23, "field_name": "HAZMAT_PLACARD_REQ", "description": "Indicates if hazardous material placards are required.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "null": "Unknown"}},
          {"order": 24, "field_name": "SNET_VERSION_NUMBER", "description": "SafetyNet version number.", "length": 7, "type": "A/N", "format": "#.#.#.#"},
          {"order": 25, "field_name": "SNET_SEARCH_DATE", "description": "SafetyNet search date and time.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 26, "field_name": "ALCOHOL_CONTROL_SUB", "description": "Indicates whether an alcohol or controlled substance check was performed.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown", "null": "Null"}},
          {"order": 27, "field_name": "DRUG_INTRDCTN_SEARCH", "description": "Indicates whether or not there was a drug interdiction search.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown", "null": "Null"}},
          {"order": 28, "field_name": "DRUG_INTRDCTN_ARRESTS", "description": "Indicates the number of drug interdiction arrests made.", "length": 2, "type": "N", "format": null},
          {"order": 29, "field_name": "SIZE_WEIGHT_ENF", "description": "Indicates whether the inspection was conducted in conjunction with a size/weight enforcement action.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown", "null": "Null"}},
          {"order": 30, "field_name": "TRAFFIC_ENF", "description": "Indicates whether the inspection was conducted in conjunction with a traffic enforcement action.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown", "null": "Null"}},
          {"order": 31, "field_name": "LOCAL_ENF_JURISDICTION", "description": "Indicates whether the inspection was conducted by a local jurisdiction.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown", "null": "Null"}},
          {"order": 32, "field_name": "PEN_CEN_MATCH", "description": "Indicates use of ASPEN carrier match.", "length": 1, "type": "A/N", "values": {"B": "B", "I": "I", "N": "N", "P": "P", "Q": "Q", "Y": "Y", "null": "Null"}},
          {"order": 33, "field_name": "FINAL_STATUS_DATE", "description": "Date and time the Status Code is changed.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 34, "field_name": "POST_ACC_IND", "description": "Indicates whether or not the inspection was conducted after an accident.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "null": "Unknown"}},
          {"order": 35, "field_name": "GROSS_COMB_VEH_WT", "description": "Total gross weight of the combination vehicle (measured in pounds).", "length": 6, "type": "A/N", "format": null},
          {"order": 36, "field_name": "VIOL_TOTAL", "description": "Total number of violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 37, "field_name": "OOS_TOTAL", "description": "Total number of out-of-service violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 38, "field_name": "DRIVER_VIOL_TOTAL", "description": "Total number of driver violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 39, "field_name": "DRIVER_OOS_TOTAL", "description": "Total number of driver out-of-service violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 40, "field_name": "VEHICLE_VIOL_TOTAL", "description": "Total number of vehicle violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 41, "field_name": "VEHICLE_OOS_TOTAL", "description": "Total number of vehicle out-of-service violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 42, "field_name": "HAZMAT_VIOL_TOTAL", "description": "Total number of hazardous material violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 43, "field_name": "HAZMAT_OOS_TOTAL", "description": "Total number of hazardous material out-of-service violations for the inspection.", "length": 3, "type": "N", "format": null},
          {"order": 44, "field_name": "SNET_SEQUENCE_ID", "description": "SafetyNet sequence ID.", "length": 10, "type": "N", "format": null},
          {"order": 45, "field_name": "TRANSACTION_CODE", "description": "Reason for upload from SafetyNet.", "length": 1, "type": "A/N", "values": {"A": "Add to MCMIS", "C": "Change existing record in MCMIS", "null": "Null"}},
          {"order": 46, "field_name": "TRANSACTION_DATE", "description": "Date and time that transaction code was entered.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 47, "field_name": "UPLOAD_DATE", "description": "Inspection upload date and time.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 48, "field_name": "UPLOAD_FIRST_BYTE", "description": "Upload census first byte.", "length": 1, "type": "A/N", "format": null},
          {"order": 49, "field_name": "UPLOAD_DOT_NUMBER", "description": "USDOT number uploaded in the inspection.", "length": 8, "type": "A/N", "format": null},
          {"order": 50, "field_name": "UPLOAD_SEARCH_INDICATOR", "description": "Upload search indicator.", "length": 1, "type": "A/N", "values": {"M": "Manual", "null": "Null"}},
          {"order": 51, "field_name": "CENSUS_SEARCH_DATE", "description": "Date and time that census number was searched.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 52, "field_name": "SNET_INPUT_DATE", "description": "Date the inspection was input into SafetyNet.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 53, "field_name": "SOURCE_OFFICE", "description": "The office that sent the inspection.", "length": 7, "type": "A/N", "format": null},
          {"order": 54, "field_name": "MCMIS_ADD_DATE", "description": "Date and time the inspection was added to MCMIS.", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 55, "field_name": "INSP_CARRIER_NAME", "description": "Name of the individual, partnership, or corporation responsible for the transportation of goods or persons.", "length": 120, "type": "A/N", "source": "Carrier Table"},
          {"order": 56, "field_name": "INSP_CARRIER_STREET", "description": "Street address of the principal place of business of the carrier.", "length": 50, "type": "A/N", "source": "Carrier Table"},
          {"order": 57, "field_name": "INSP_CARRIER_CITY", "description": "Municipality (city or township) of the principal place of business of the carrier.", "length": 25, "type": "A/N", "source": "Carrier Table"},
          {"order": 58, "field_name": "INSP_CARRIER_STATE", "description": "State/District/Province of the principal place of business of the carrier.", "length": 2, "type": "A/N", "source": "Carrier Table", "format": "See State Abbreviations"},
          {"order": 59, "field_name": "INSP_CARRIER_ZIP_CODE", "description": "ZIP code of the principal place of business of the carrier.", "length": 10, "type": "A/N", "source": "Carrier Table"},
          {"order": 60, "field_name": "INSP_COLONIA", "description": "Carrier's Mexican Colonia (for Mexican domiciled carriers).", "length": 25, "type": "A/N", "source": "Carrier Table"},
          {"order": 61, "field_name": "DOCKET_NUMBER", "description": "Docket number (MC, MX, or FF number) assigned by FMCSA or the former ICC to the carrier.", "length": 8, "type": "N", "source": "Carrier Table"},
          {"order": 62, "field_name": "INSP_INTERSTATE", "description": "Indicates whether the carrier is involved in interstate commerce.", "length": 1, "type": "A/N", "source": "Carrier Table", "values": {"Y": "Yes", "N": "No", "null": "Null"}},
          {"order": 63, "field_name": "INSP_CARRIER_STATE_ID", "description": "Identification number assigned by the state to the carrier.", "length": 12, "type": "A/N", "source": "Carrier Table"}
        ],
        "removed_fields": [
          {"field_name": "INSP_CONFIDENCE_LEVEL", "description": "Inspector Confidence Level", "length": 1, "type": "A/N"},
          {"field_name": "PENFIELD2", "description": "Pen Field 2", "length": 1, "type": "A/N", "values": "0 or Null"},
          {"field_name": "PENFIELD3", "description": "Pen Field 3", "length": 1, "type": "A/N", "values": "0-9, E, N, or Null"},
          {"field_name": "DEFECT_VER", "description": "Defect Verification (no longer used)", "length": 1, "type": "A/N"},
          {"field_name": "OOS_DEFECT_VER", "description": "Out-of-Service Defect Verification", "length": 1, "type": "A/N"},
          {"field_name": "VIOL_NOT_SENT", "description": "Violations Not Sent", "length": 2, "type": "N"},
          {"field_name": "OOS_NOT_SENT", "description": "Out-of-Service Not Sent", "length": 2, "type": "N"},
          {"field_name": "ORIG_REPORT_STATE", "description": "Original Report State", "length": 2, "type": "A/N"},
          {"field_name": "ORIG_REPORT_NUMBER", "description": "Original Report Number", "length": 10, "type": "A/N"},
          {"field_name": "ORIG_REPORT_DATE", "description": "Original Inspection Date", "length": 8, "type": "A/N", "format": "YYYYMMDD"},
          {"field_name": "ORIG_REPORT_TIME", "description": "Original Start Time", "length": 4, "type": "A/N"},
          {"field_name": "INSP_CARRIER_ID", "description": "Carrier ID (from old Carrier Table)", "length": 8, "type": "N"},
          {"field_name": "PREFIX", "description": "Prefix (from old Carrier Table)", "length": 2, "type": "A/N"}
        ]
      },
      "inspections_per_unit": {
        "description": "Contains vehicle unit details linked to an inspection record.",
        "fields": [
          {"order": 1, "field_name": "CHANGE_DATE", "description": "Date and time record was last updated", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 2, "field_name": "INSPECTION_ID", "description": "Unique identifying number assigned to an inspection record.", "length": 8, "type": "N"},
          {"order": 3, "field_name": "INSP_UNIT_ID", "description": "Unique identifying number assigned to an inspected unit.", "length": 9, "type": "N"},
          {"order": 4, "field_name": "INSP_UNIT_TYPE_ID", "description": "Code identifying the type of vehicle unit.", "length": 8, "type": "N", "values": {
            "1": "BU - Bus",
            "2": "DC - Dolly Converter",
            "3": "FT - Full Trailer",
            "4": "LM - Limousine",
            "5": "MC - Motor Carrier",
            "6": "OT - Other",
            "7": "PT - Pole Trailer",
            "8": "SB - School Bus",
            "9": "ST - Semi Trailer",
            "10": "TR - Straight Truck",
            "11": "TT - Truck Tractor",
            "12": "VN - Van",
            "13": "ZZ - Unknown",
            "14": "Intermodal Chassis",
            "15": "Crib Log Trailer"
          }},
          {"order": 5, "field_name": "INSP_UNIT_NUMBER", "description": "Sequence number of the vehicle unit (1-6).", "length": 1, "type": "N"},
          {"order": 6, "field_name": "INSP_UNIT_MAKE", "description": "Manufacturer of the vehicle unit.", "length": 10, "type": "A/N"},
          {"order": 7, "field_name": "INSP_UNIT_COMPANY", "description": "Number assigned to the vehicle unit by the carrier.", "length": 15, "type": "A/N"},
          {"order": 8, "field_name": "INSP_UNIT_LICENSE", "description": "License tag number on the vehicle unit.", "length": 12, "type": "A/N"},
          {"order": 9, "field_name": "INSP_UNIT_LICENSE_STATE", "description": "State/District/Province issuing the license tags.", "length": 2, "type": "A/N", "format": "See State Abbreviations"},
          {"order": 10, "field_name": "INSP_UNIT_VEHICLE_ID_NUMBER", "description": "Vehicle Identification Number (VIN) of the unit.", "length": 17, "type": "A/N"},
          {"order": 11, "field_name": "INSP_UNIT_DECAL", "description": "Indicates whether a CVSA decal was issued.", "length": 1, "type": "A/N", "values": {"Y": "Yes", "N": "No", "U": "Unknown"}},
          {"order": 12, "field_name": "INSP_UNIT_DECAL_NUMBER", "description": "Number on the CVSA decal.", "length": 8, "type": "A/N"}
        ]
      },
      "vehicle_inspections_and_violations": {
        "description": "Contains violation details linked to an inspection record.",
        "fields": [
          {"order": 1, "field_name": "CHANGE_DATE", "description": "Date and time record was last updated", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 2, "field_name": "INSPECTION_ID", "description": "Unique identifying number assigned to an inspection record.", "length": 8, "type": "N"},
          {"order": 3, "field_name": "INSP_VIOLATION_ID", "description": "Unique identifying number assigned to a violation.", "length": 9, "type": "N"},
          {"order": 4, "field_name": "SEQ_NO", "description": "Sequence number of the violation.", "length": 3, "type": "N"},
          {"order": 5, "field_name": "PART_NO", "description": "Part number of the violation cited (Reference FMCSR, HMR).", "length": 3, "type": "A/N"},
          {"order": 6, "field_name": "PART_NO_SECTION", "description": "Section number of the violation cited (Reference FMCSR, HMR).", "length": 40, "type": "A/N"},
          {"order": 7, "field_name": "INSP_VIOL_UNIT", "description": "Driver, co-driver, or vehicle unit number which had the violation.", "length": 1, "type": "A/N", "values": "D, C, 1-6"},
          {"order": 8, "field_name": "INSP_UNIT_ID", "description": "Unique identifying number assigned to an inspected unit.", "length": 9, "type": "N"},
          {"order": 9, "field_name": "INSP_VIOLATION_CATEGORY_ID", "description": "Category number assigned to the violation (1-99). See Violation Categories.", "length": 8, "type": "N"},
          {"order": 10, "field_name": "OUT_OF_SERVICE_INDICATOR", "description": "Indicates whether the violation resulted in an out-of-service.", "length": 1, "type": "A/N", "values": {"Z": "Driver Yes", "Y": "Yes", "N": "No", "null": "Null"}},
          {"order": 11, "field_name": "DEFECT_VERIFICATION_ID", "description": "Defect verification status.", "length": 8, "type": "N", "values": {
            "1": "A - Repaired at scene",
            "2": "B - Towed/Escorted to repair service",
            "3": "N - Non-OOS/Driver Non-OOS",
            "4": "D - Other",
            "99": "U - Unknown/Unverified"
          }},
          {"order": 12, "field_name": "CITATION_NUMBER", "description": "Number identifying the citation.", "length": 15, "type": "A/N"}
        ]
      },
      "special_studies": {
        "description": "Contains data collected as part of special studies linked to an inspection.",
        "fields": [
          {"order": 1, "field_name": "CHANGE_DATE", "description": "Date and time record was last updated", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 2, "field_name": "INSPECTION_ID", "description": "Unique identifying number assigned to an inspection record.", "length": 8, "type": "N"},
          {"order": 3, "field_name": "INSP_STUDY_ID", "description": "Unique identifying number assigned to a study.", "length": 8, "type": "N"},
          {"order": 4, "field_name": "STUDY", "description": "Data collected as part of a special study.", "length": 40, "type": "A/N"},
          {"order": 5, "field_name": "SEQ_NO", "description": "Sequence number of the special study (indicates data in Study field 1-5).", "length": 3, "type": "N"}
        ]
      },
      "inspections_and_citations": {
        "description": "Contains citation details linked to inspection violations.",
        "fields": [
          {"order": 1, "field_name": "CHANGE_DATE", "description": "Date and time record was last updated", "length": 13, "type": "N", "format": "YYYYMMDD HHMM (Military Time)"},
          {"order": 2, "field_name": "INSPECTION_ID", "description": "Unique identifying number assigned to an inspection record.", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"order": 3, "field_name": "VIOSEQNUM", "description": "Sequence number of a violation.", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"order": 4, "field_name": "ADJSEQ", "description": "Adjusted sequence number of a violation.", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"order": 5, "field_name": "CITATION_CODE", "description": "Citation code.", "length": 8, "type": "N", "source": "INSP_CITATION_CODE"},
          {"order": 6, "field_name": "CITATION_RESULT", "description": "Result of the citation.", "length": 100, "type": "A/N", "source": "INSP_CITATION_CODE"}
        ],
        "removed_fields": [
          {"field_name": "CHALLENGEID", "description": "Challenge ID", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"field_name": "CITATIONRESULT", "description": "Citation Result (old)", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"field_name": "RESULTDATE", "description": "Result Date", "length": 8, "type": "A/N", "format": "YYYYMMDD", "source": "INSP_VIOL_CITATION"},
          {"field_name": "COMMENTS", "description": "Comments", "length": 512, "type": "A/N", "source": "INSP_VIOL_CITATION"},
          {"field_name": "CHANGESOURCE", "description": "Change Source", "length": 8, "type": "N", "source": "INSP_VIOL_CITATION"},
          {"field_name": "UPLOADDATE", "description": "Upload Date", "length": 8, "type": "A/N", "format": "YYYYMMDD", "source": "INSP_VIOL_CITATION"},
          {"field_name": "ADDDATE", "description": "Add Date", "length": 8, "type": "A/N", "format": "YYYYMMDD", "source": "INSP_VIOL_CITATION"},
          {"field_name": "ADDUSER", "description": "Add User", "length": 30, "type": "A/N", "source": "INSP_VIOL_CITATION"},
          {"field_name": "CHANGE_DATE", "description": "Change Date (old citation code table)", "length": 8, "type": "A/N", "format": "YYYYMMDD", "source": "INSP_CITATION_CODE"},
          {"field_name": "CHANGE_BY_USER", "description": "Change By User", "length": 30, "type": "A/N", "source": "INSP_CITATION_CODE"}
        ]
      }
    },
    "violation_categories": {
      "driver_violations": [
