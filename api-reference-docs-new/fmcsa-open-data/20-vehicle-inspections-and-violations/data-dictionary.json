        {"category_number": 6, "code": "60/70", "description": "60/70/80 Hours"},
        {"category_number": 7, "code": "OTHHOS", "description": "All Other Hours-Of-Service"},
        {"category_number": 8, "code": "DSQDRV", "description": "Disqualified Drivers"},
        {"category_number": 9, "code": "DRUGS", "description": "Drugs"},
        {"category_number": 10, "code": "ALCOHL", "description": "Alcohol"},
