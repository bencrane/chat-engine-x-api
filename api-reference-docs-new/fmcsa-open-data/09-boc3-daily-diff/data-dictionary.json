{
    "document": {
      "title": "Dataset Description and Data Definitions",
      "subtitle": "For Select Datasets on DOT's Open Data Catalog",
      "source": "U.S. Department of Transportation — Federal Motor Carrier Safety Administration (FMCSA)",
      "catalog_url": "https://data.transportation.gov",
      "update_frequency": "Daily by 9:30 AM US Eastern Time"
    },
    "naming_conventions": {
      "daily_difference": {
        "format": "[Dataset Name]",
        "description": "Includes records that have been updated or added since the previous run. May include all other records for the carrier/broker/freight forwarder for completeness."
      },
      "full_baseline": {
        "format": "[Dataset Name] – All With History",
        "description": "Includes all records (including historical values where appropriate) as of the latest dataset update."
      }
    },
    "datasets": [
      {
        "id": 1,
        "name": "Carrier",
        "variants": ["Carrier", "Carrier– All With History"],
