      {
        "id": 2,
        "name": "Insur",
        "variants": ["Insur", "Insur– All With History"],
        "description": "Records for carrier/broker/freight forwarder active or pending individual insurance policies. Linked by docket number. Entities can hold multiple policies. The daily difference variant shows removals as blank records (empty or '00000' values except docket number).",
        "fields": [
          {
            "number": 1,
            "name": "Docket Number",
            "format": "Text 8",
            "definition": "Unique FMCSA number identifying for-hire motor carriers (MC000000, FF000000 or MX000000)"
          },
          {
            "number": 2,
            "name": "Insurance Type",
            "format": "Text 1",
            "definition": "Type of insurance policy",
            "values": {
              "1": "BI&PD",
              "2": "Cargo",
              "3": "Bond",
              "4": "Trust Fund"
            },
            "note": "For Insurance Type 1, amounts are in fields #4 and #5. For types 2, 3, and 4, fields #4 and #5 will be 0."
          },
          {
            "number": 3,
            "name": "BI&PD Class",
            "format": "Text 1",
            "definition": "BI&PD insurance classification",
            "values": {
              "P": "Primary",
              "E": "Excess",
              "1": "Full Security Limits Under Section 1043.2(b)(1)",
              "2": "Full Security Limits Under Section 1043.2(b)(2)"
            }
          },
          {
            "number": 4,
            "name": "BI&PD Maximum Dollar Limit",
            "format": "Text 5",
            "definition": "Maximum liability amount in thousands (company shall not be liable for amounts in excess of)"
          },
          {
            "number": 5,
            "name": "BI&PD Underlying Dollar Limit",
            "format": "Text 5",
            "definition": "Underlying limit amount in thousands"
          },
          {
            "number": 6,
            "name": "Policy Number",
            "format": "Text 25",
            "definition": "Insurance policy specific identifier"
          },
          {
            "number": 7,
            "name": "Effective Date",
            "format": "Text 10",
            "definition": "Effective date of the policy"
          },
          {
            "number": 8,
            "name": "Form Code",
            "format": "Text 3",
            "definition": "Insurance form type code",
            "values": {
              "34": "Cargo",
              "82": "BI&PD",
              "83": "Cargo",
              "84": "Property Broker's Surety Bond",
              "85": "Property Broker's Trust Fund Agreement",
              "91": "BI&PD",
              "91X": "BI&PD/Primary, BI&PD/Excess"
            }
          },
          {
            "number": 9,
            "name": "Insurance Company Name",
            "format": "Text 45",
            "definition": "Insurance company name for policy (note: policy may be administered by a company branch with a different name)"
          }
        ]
      },
