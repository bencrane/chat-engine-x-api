            "length": 2,
            "type": "A/N",
            "format": "1, 3-10",
            "values": {
              "1": "CT, ME, MA, NH, NY, NJ, RI, VT, PR, VI",
              "3": "DE, DC, MD, PA, VA, WV",
              "4": "AL, GA, FL, MS, NC, SC, TN, KY",
              "5": "IL, IN, MI, OH, MN, WI",
              "6": "AR, LA, NM, OK, TX",
              "7": "IA, KS, MO, NE",
              "8": "CO, MT, ND, SD, UT, WY",
              "9": "AZ, CA, NV, HI, GU, AS",
              "10": "AK, ID, OR, WA"
            }
          },
          {
            "order": 11,
            "field_name": "CI_STATUS_CODE",
            "description": "Status of the inspection",
            "length": 1,
            "type": "A/N",
            "format": "U, T, C, D, N, H, I, P, or X",
            "values": {
              "U": "Unprocessed",
              "T": "To Census Search",
              "C": "Complete",
              "D": "Duplicate",
              "N": "Nonmatch",
              "H": "FMCSA hold",
              "I": "Intrastate",
              "P": "Potential Resolution",
              "X": "Non-motor carrier"
            }
          },
          {
            "order": 12,
            "field_name": "LOCATION",
            "description": "State assigned code representing the physical location of the inspection",
            "length": 6,
            "type": "A/N",
            "format": "1-5, 9"
          },
          {
            "order": 13,
            "field_name": "LOCATION_DESC",
            "description": "Physical location where the inspection took place",
            "length": 30,
            "type": "A/N",
            "format": null
          },
          {
            "order": 14,
            "field_name": "COUNTY_CODE_STATE",
            "description": "State/District/Province of the county where the inspection took place",
            "length": 2,
            "type": "A/N",
            "format": "See State Abbreviations"
          },
          {
            "order": 15,
            "field_name": "COUNTY_CODE",
            "description": "FIPS code identifying the county in which the inspection occurred",
            "length": 3,
            "type": "A/N",
            "format": "See County Codes"
          },
          {
            "order": 16,
            "field_name": "INSP_LEVEL_ID",
            "description": "Inspection level identifier",
            "length": 8,
            "type": "N",
            "format": "1, 2, 3, 4, 5, or 99",
            "values": {
              "1": "Full",
              "2": "Walk-Around",
              "3": "Driver-Only",
              "4": "Special Study",
              "5": "Terminal",
              "99": "Invalid"
            }
          },
          {
            "order": 17,
            "field_name": "SERVICE_CENTER",
            "description": "Service Center Region the inspection occurred in",
            "length": 2,
            "type": "A/N",
            "format": "MW, EA, SH, WE",
            "values": {
              "MW": "Midwest",
              "EA": "East",
              "SH": "South",
              "WE": "West"
            }
          },
          {
            "order": 18,
            "field_name": "CENSUS_SOURCE_ID",
            "description": "USDOT NUMBER verification method",
            "length": 8,
            "type": "N",
            "format": "1, 2, 3, 4, or 5",
            "values": {
              "1": "Matchware",
              "2": "Manual Census Search",
              "3": "Matching Algorithm",
              "4": "Pen-Based (not used on Crashes)",
              "5": "SafetyNet Uploaded and not changed"
            }
          },
          {
            "order": 19,
            "field_name": "INSP_FACILITY",
            "description": "Type of facility where the inspection was conducted",
            "length": 1,
            "type": "A/N",
            "format": "F, R, or Null",
            "values": {
              "F": "Fixed",
              "R": "Roadside",
              "Null": "N/A"
            }
          },
          {
            "order": 20,
            "field_name": "SHIPPER_NAME",
            "description": "Name of the shipping company",
            "length": 120,
            "type": "A/N",
            "format": null
          },
          {
            "order": 21,
            "field_name": "SHIPPING_PAPER_NUMBER",
            "description": "Unique number on the shipping papers or NONE if not present",
            "length": 15,
            "type": "A/N",
            "format": null
          },
          {
            "order": 22,
            "field_name": "CARGO_TANK",
