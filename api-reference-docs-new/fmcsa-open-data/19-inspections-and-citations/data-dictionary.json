    "tables": {
      "vehicle_inspection_file": {
        "description": "Main vehicle inspection file table containing inspection-level data",
        "fields": [
          {
            "order": 1,
            "field_name": "CHANGE_DATE",
            "description": "Date & time record was last updated",
            "length": 13,
            "type": "N",
            "format": "YYYYMMDD HHMM (Military Time)"
          },
          {
            "order": 2,
            "field_name": "INSPECTION_ID",
            "description": "Unique identifying number assigned to an inspection record",
            "length": 8,
            "type": "N",
            "format": null
          },
          {
            "order": 3,
            "field_name": "DOT_NUMBER",
            "description": "USDOT number assigned by MCMIS to a census record",
            "length": 8,
            "type": "N",
            "format": null
          },
          {
            "order": 4,
            "field_name": "REPORT_STATE",
            "description": "State/District/Province which uploads the inspection",
            "length": 2,
            "type": "A/N",
            "format": "See State Abbreviations"
          },
          {
            "order": 5,
            "field_name": "REPORT_NUMBER",
            "description": "Number identifying the inspection report",
            "length": 10,
            "type": "A/N",
            "format": "SS######## (SS=State code or US for Federal)"
          },
          {
            "order": 6,
            "field_name": "INSP_DATE",
            "description": "Date the inspection was conducted",
            "length": 8,
            "type": "A/N",
            "format": "YYYYMMDD"
          },
          {
            "order": 7,
            "field_name": "INSP_START_TIME",
            "description": "Time the inspection started",
            "length": 4,
            "type": "A/N",
            "format": "HHMM military time; 2400=midnight; 9999=unknown"
          },
          {
            "order": 8,
            "field_name": "INSP_END_TIME",
            "description": "Time the inspection ended",
            "length": 4,
            "type": "A/N",
            "format": "HHMM military time; 2400=midnight; 9999=unknown"
          },
          {
            "order": 9,
            "field_name": "REGISTRATION_DATE",
            "description": "Date the certification of correction of defects was registered",
            "length": 8,
            "type": "A/N",
            "format": "YYYYMMDD"
          },
          {
