# =============================================================================
# chat-engine-x-api — Environment Variables
# All managed via Doppler in production. This file documents required vars.
# =============================================================================

# --- Server ---
PORT=8080
NODE_ENV=development

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-4-20250514

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Data Engine X ---
DATA_ENGINE_X_URL=https://data-engine-x.example.com
DATA_ENGINE_X_TOKEN=your-dex-token

# --- Creative Engine X ---
CREATIVE_ENGINE_X_URL=https://creative-engine-x.example.com
CREATIVE_ENGINE_X_TOKEN=your-cex-token

# --- Outbound Engine X ---
OUTBOUND_ENGINE_X_URL=https://outbound-engine-x.example.com
OUTBOUND_ENGINE_X_TOKEN=your-oex-token

# --- Paid Engine X ---
PAID_ENGINE_X_URL=https://paid-engine-x.example.com
PAID_ENGINE_X_TOKEN=your-paid-engine-x-token

# --- Auth ---
JWT_SECRET=your-jwt-secret

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
