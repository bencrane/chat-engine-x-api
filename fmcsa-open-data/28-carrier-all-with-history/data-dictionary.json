      "InsHist": {
        "description": "Previous (historical) insurance policies for carriers/brokers/freight forwarders. Contains cancellation method, policy type, policy number, effective and cancellation dates. Important: all insurance info relates to the policy being cancelled/replaced/name-changed \u2014 NOT the subsequent policy.",
        "fields": [
          {
            "order": 1,
            "name": "Docket Number",
            "format": "Text 8",
            "definition": "Unique FMCSA number identifying for-hire motor carriers (MC000000, FF000000 or MX000000)"
          },
          {
            "order": 2,
            "name": "USDOT Number",
            "format": "Text 8",
            "definition": "Official FMCSA registration number for all interstate motor carriers"
          },
          {
            "order": 3,
            "name": "Form Code",
            "format": "Text 3",
            "definition": "Insurance form code",
            "values": {
              "34": "Cargo",
              "82": "BI&PD",
              "83": "Cargo",
              "84": "Property Broker's Surety Bond",
              "85": "Property Broker's Trust Fund Agreement",
              "91": "BI&PD",
              "91X": "BI&PD/Primary or BI&PD/Excess"
            }
          },
          {
            "order": 4,
            "name": "Cancellation Method",
            "format": "Text 12",
            "definition": "Method of cancellation",
            "values": [
              "cancelled",
              "replaced",
              "name change",
              "transferred"
            ]
          },
          {
            "order": 5,
            "name": "Cancel/Replace/Name Change/Transfer Form",
            "format": "Text 6",
            "definition": "The form that executed the cancellation, replacement, name change, or transfer",
            "cancellation_codes": {
              "35": "BMC Cancellation Form",
              "36": "BMC Surety Bond Cancellation Form",
              "85C": "BMC Cancellation for Trust Funds"
            },
            "replacement_codes": "Same form codes as field #3",
