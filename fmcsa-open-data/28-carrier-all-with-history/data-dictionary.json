{
    "metadata": {
      "title": "FMCSA Dataset Description and Data Definitions - Select Datasets",
      "source": "FMCSA - Federal Motor Carrier Safety Administration",
      "catalog_url": "https://data.transportation.gov",
      "pages": 15,
      "update_frequency": "Daily by 9:30AM US Eastern Time",
      "total_datasets": 16
    },
    "naming_convention": {
      "daily_difference": {
        "pattern": "[Dataset Name]",
        "description": "Includes records updated or added since the previous run. May include all other records for the carrier/broker/freight forwarder for completeness."
      },
      "full_baseline": {
        "pattern": "[Dataset Name] - All With History",
        "description": "Full/Baseline dataset including all records (including historical values where appropriate) as of the latest dataset update."
      }
    },
    "datasets": {
      "Carrier": {
        "description": "Records for all carriers/brokers/freight forwarders with active, inactive, or pending authorities (common or contract). Includes DOT number, docket number, entity census, authority, and insurance data.",
        "fields": [
          {
            "order": 1,
            "name": "Docket Number",
            "format": "Text 8",
            "definition": "Unique FMCSA number identifying for-hire motor carriers (MC000000, FF000000 or MX000000)"
          },
          {
            "order": 2,
            "name": "USDOT Number",
            "format": "Text 8",
            "definition": "Official FMCSA registration number for all interstate motor carriers"
          },
          {
            "order": 3,
            "name": "MX Type",
            "format": "Text 1",
            "definition": "FMCSA character distinguishing Mexican carriers",
            "values": {
              "X": "OP-1 (Operate throughout US)",
              "Z": "OP-2 (Operate in Commercial Zones only)"
            }
          },
          {
            "order": 4,
            "name": "RFC Number",
