          },
          {
            "order": 7,
            "name": "Insurance Type Description",
            "format": "Text 12",
            "definition": "Description of insurance form/class"
          },
          {
            "order": 8,
            "name": "Policy Number",
            "format": "Text 25",
            "definition": "Insurance policy specific identifier"
          },
          {
